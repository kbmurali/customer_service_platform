# LLM Provider Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

AGENT_TIMEOUT_SECONDS=300
AGENT_MAX_RETRIES=1
AGENT_RETRY_BACKOFF_DELAY_SECONDS=10

OPENAI_API_KEY=<your_api_key> 
OPENAI_EMBEDDING_MODEL = text-embedding-3-small

# Anthropic Configuration
ANTHROPIC_API_KEY=<your_api_key> 

# Turn on tracing
LANGCHAIN_TRACING_V2=true              # or LANGSMITH_TRACING=true in newer setups

# Tell LangSmith which project to group traces into
LANGCHAIN_PROJECT=agentic-patterns  # or LANGSMITH_PROJECT=member-service-demo

# Hosted LangSmith endpoint + key
LANGSMITH_API_KEY=<your_api_key> 

LANGSMITH_ENDPOINT=https://api.smith.langchain.com

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neoadmin

NEO4J_KG_URI=bolt://localhost:7687
NEO4J_KG_USER=neo4j
NEO4J_KG_PASSWORD=neo4j_kg_admin

NEO4J_CG_URI=bolt://localhost:7688
NEO4J_CG_USER=neo4j
NEO4J_CG_PASSWORD=neo4j_cg_admin

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=app_user
MYSQL_PASSWORD=mysql_admin
MYSQL_DATABASE=health_insurance

CHROMA_HOST=localhost
CHROMA_PORT=8000

# CircuitBreaker and Workflow Approvals Tracking
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_VAULT_DB=2
VAULT_ENCRYPTION_KEY=<your_vault_encryption_key> 

# Vector Database Configuration
VECTOR_DB_PROVIDER=chroma
CHROMA_PERSIST_DIRECTORY=./data/chroma

# LangFuse Configuration
LANGFUSE_SECRET_KEY=<your_langfuse_secret_key> 
LANGFUSE_PUBLIC_KEY=<your_langfuse_public_key>
LANGFUSE_HOST=http://localhost:3001

# Application Configuration
APP_ENV=development
LOG_LEVEL=INFO

MCP_SERVER_HOST="0.0.0.0"
MCP_SERVER_PORT=8001

MCP_CLIENT_CERT=/home/kbmurali/tmp/certs/mcp/client.crt
MCP_CLIENT_KEY=/home/kbmurali/tmp/certs/mcp/client.key
MCP_CA_CERT=/home/kbmurali/tmp/certs/mcp/ca.crt

MCP_MASTER_SECRET=<your_mcp_master_secret>

MCP_MEMBER_SERVICES_HTTP_URL=https://localhost:8443/mcp/member

A2A_MEMBER_SERVICES_URL=https://localhost:8443/a2a/member

MCP_CLAIMS_SERVICES_HTTP_URL=https://localhost:8443/mcp/claims

A2A_CLAIMS_SERVICES_URL=https://localhost:8443/a2a/claims

MCP_PA_SERVICES_HTTP_URL=https://localhost:8443/mcp/pa

A2A_PA_SERVICES_URL=https://localhost:8443/a2a/pa

MCP_PROVIDER_SERVICES_HTTP_URL=https://localhost:8443/mcp/provider

A2A_PROVIDER_SERVICES_URL=https://localhost:8443/a2a/provider

MCP_SEARCH_SERVICES_HTTP_URL=https://localhost:8443/mcp/search

A2A_SEARCH_SERVICES_URL=https://localhost:8443/a2a/search

CONTEXT_COMPRESSION_ENABLED=true
CONTEXT_COMPRESSION_MAX_VERBATIM_TURNS=2
CONTEXT_COMPRESSION_RATE=0.5
CONTEXT_COMPRESSION_MODEL=openai-community/gpt2
CONTEXT_COMPRESSION_DEVICE=cpu
CONTEXT_COMPRESSION_SEMANTIC_RATE=0.3
CONTEXT_COMPRESSION_CROSS_AGENT_RATE=0.4